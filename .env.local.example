# =====================================================
# VIVID WINS — environment variables
# Copy this file to `.env.local` and fill in the values.
# Never commit .env.local to git (it's in .gitignore).
# =====================================================

# ---------- Supabase ----------
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...YOUR_ANON_KEY
# KEEP THIS SECRET — server-side only, bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...YOUR_SERVICE_ROLE_KEY

# ---------- Stripe (TEST MODE) ----------
# Get these from https://dashboard.stripe.com/test/apikeys
# Use sk_test_... and pk_test_... only until you're ready to go live
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
# Webhook signing secret — generated when you create a webhook endpoint
# Local dev: get from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Production: from https://dashboard.stripe.com/test/webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to https://vividwins.co.uk (or wherever) in production
